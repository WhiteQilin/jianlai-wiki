# Raw official/media archives - local only
public/images/official/
public/videos/all-mp4/
public/videos/official/
public/videos/raw/
public/media/official/
public/media/raw/

# Design/reference drafts
design-references/
public/images/design-references/
public/images/banner-draft/
public/images/weibo-draft/

# Raw/draft image dumps
public/images/banners/pinterest_*.jpg

# Local font experiments
public/fonts/*

# Allow deployed production fonts only
!public/fonts/production/
