# Local AI prompt packs
.github/prompts/ui-ux-pro-max/

# Ignore large videos by default
*.mp4
*.mov
*.mkv
*.avi
*.webm

# Allow only curated optimized videos
!public/videos/
!public/videos/curated/
!public/videos/curated/**

# Python/cache
__pycache__/
*.pyc
